# Supabase (get from supabase.com after creating project)
NEXT_PUBLIC_SUPABASE_URL=your-project-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend (https://resend.com) API key from Dashboard. For local testing, FROM_EMAIL can stay onboarding@resend.dev.
RESEND_API_KEY=your-resend-api-key-here
FROM_EMAIL=Ground Work <onboarding@resend.dev>

# Public site URL for links in broadcast emails (no trailing slash). Use your production domain in Vercel.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin credentials (must match a real Supabase Auth email/password account)
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=your-strong-admin-password
